# NeoStats AI Chatbot - Environment Configuration Example
# 
# Copy this file to .env.local and fill in your actual API keys
# .env.local is in .gitignore and will not be committed to GitHub

# === LLM Provider Keys ===

# Groq API Key (Recommended - Fast & Free)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI API Key (Optional)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini API Key (Optional)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# === Web Search ===

# Tavily API Key (For live web search)
# Get from: https://app.tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# === RAG Configuration ===

# Embedding Model (HuggingFace)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Vector Database Path
VECTOR_DB_PATH=./.vector_db

# Knowledge Base Path (where your local documents go)
KNOWLEDGE_BASE_PATH=./knowledge_base

# RAG Chunking Parameters
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4

# === Setup Instructions ===
# 
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your API keys in .env.local
# 3. Never commit .env.local to version control
# 4. In terminal, load variables: source .env.local
# 5. Or use: export $(cat .env.local | xargs)
# 6. Then run: python3 run.py
